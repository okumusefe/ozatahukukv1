<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Özata Hukuk - İzmir'in tüm ilçelerinde ve Türkiye genelinde hukuki hizmet. Aliağa, Balçova, Bayındır, Bayraklı, Bergama, Beydağ, Bornova, Buca, Çeşme, Çiğli ve daha fazla ilçede avukatlık hizmetleri.">
    <meta name="keywords" content="İzmir avukat, Aliağa avukat, Balçova avukat, Bayındır avukat, Bayraklı avukat, Bergama avukat, Beydağ avukat, Bornova avukat, Buca avukat, Çeşme avukat, Çiğli avukat, Dikili avukat, Foça avukat, Gaziemir avukat, Güzelbahçe avukat, Karabağlar avukat, Karaburun avukat, Karşıyaka avukat, Kemalpaşa avukat, Kınık avukat, Kiraz avukat, Konak avukat, Menderes avukat, Menemen avukat, Narlıdere avukat, Ödemiş avukat, Seferihisar avukat, Selçuk avukat, Tire avukat, Torbalı avukat, Urla avukat">
    <link rel="icon" type="image/png" sizes="32x32" href="favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="favicon-16x16.png">
    <link rel="apple-touch-icon" sizes="180x180" href="apple-touch-icon.png">
    <link rel="shortcut icon" href="favicon.ico">
    <title>Özata Hukuk - Çalışma Bölgelerimiz | İzmir ve Tüm İlçeleri</title>
    <link rel="stylesheet" href="styles.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        .district-section {
            padding: 80px 0;
        }
        .district-section.alt-bg {
            background: linear-gradient(180deg, #f8f9fa 0%, #ffffff 100%);
        }
        .district-header {
            text-align: center;
            margin-bottom: 50px;
        }
        .district-header h2 {
            font-size: 2.5rem;
            color: var(--primary-color);
            margin-bottom: 15px;
        }
        .district-header p {
            color: var(--text-light);
            max-width: 700px;
            margin: 0 auto;
        }
        .district-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            margin-top: 40px;
        }
        .district-card {
            background: var(--white);
            border-radius: 15px;
            padding: 35px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.08);
            transition: all 0.3s ease;
            border-top: 4px solid var(--accent-color);
        }
        .district-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 60px rgba(0,0,0,0.12);
        }
        .district-card h3 {
            font-size: 1.4rem;
            color: var(--primary-color);
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .district-icon {
            width: 40px;
            height: 40px;
            background: rgba(201,169,97,0.1);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--accent-color);
        }
        .district-card .services-list {
            list-style: none;
            padding: 0;
            margin: 20px 0;
        }
        .district-card .services-list li {
            padding: 8px 0;
            padding-left: 25px;
            position: relative;
            color: var(--text-color);
            font-size: 0.95rem;
            border-bottom: 1px solid #f0f0f0;
        }
        .district-card .services-list li:last-child {
            border-bottom: none;
        }
        .district-card .services-list li::before {
            content: '✓';
            position: absolute;
            left: 0;
            color: var(--accent-color);
            font-weight: bold;
        }
        .district-card .contact-info {
            background: var(--bg-light);
            padding: 20px;
            border-radius: 10px;
            margin-top: 20px;
        }
        .district-card .contact-info p {
            margin: 5px 0;
            font-size: 0.9rem;
            color: var(--text-color);
        }
        .district-card .contact-info strong {
            color: var(--primary-color);
        }
        .city-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 25px;
            margin-top: 40px;
        }
        .city-card {
            background: var(--white);
            border-radius: 12px;
            padding: 30px;
            text-align: center;
            box-shadow: 0 5px 20px rgba(0,0,0,0.08);
            transition: all 0.3s ease;
        }
        .city-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.12);
        }
        .city-card .city-icon {
            width: 60px;
            height: 60px;
            background: rgba(201,169,97,0.1);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            color: var(--accent-color);
        }
        .city-card h3 {
            font-size: 1.3rem;
            color: var(--primary-color);
            margin-bottom: 10px;
        }
        .city-card .city-type {
            color: var(--accent-color);
            font-weight: 600;
            font-size: 0.9rem;
            margin-bottom: 10px;
        }
        .city-card p {
            color: var(--text-light);
            font-size: 0.95rem;
        }
        @media (max-width: 768px) {
            .district-grid {
                grid-template-columns: 1fr;
            }
            .city-grid {
                grid-template-columns: 1fr;
            }
            .district-header h2 {
                font-size: 2rem;
            }
        }
    </style>
</head>
